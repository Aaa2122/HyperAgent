AGENT_MODE=paper
TRADING_PROFILE=conservative
MAX_MODEL_LEVERAGE=5
AUTOMATION_ENABLED=false
CYCLE_INTERVAL_SECONDS=300
RISK_MONITOR_INTERVAL_SECONDS=10
# always | us_equities | crypto_sessions | hybrid. The default is unchanged:
# 24/7 scheduling with no deterministic liquidity probe.
ACTIVATION_MODE=always
ACTIVATION_TIMEZONE=UTC
US_EQUITIES_SESSIONS=["market_open","first_hours","before_close"]
CRYPTO_SESSIONS=["asia","europe","us"]
LIQUIDITY_FILTER_ENABLED=false
LIQUIDITY_MIN_24H_VOLUME_USD=25000000
LIQUIDITY_MIN_OPEN_INTEREST_USD=10000000
LIQUIDITY_MIN_ELIGIBLE_ASSETS=1
X_RESEARCH_CACHE_SECONDS=900
STRATEGIST_REFRESH_SECONDS=1800
DATABASE_URL=sqlite:///./agent.db
PAPER_EQUITY_USD=10000
MARKET_DATA_PROVIDER=paper
HYPERLIQUID_NETWORK=mainnet
# Public master/sub-account address. Do not use the API-wallet address here.
HYPERLIQUID_ACCOUNT_ADDRESS=
HYPERLIQUID_TIMEOUT_SECONDS=10

# Signed execution requires a dedicated API wallet on the selected network.
HYPERLIQUID_EXECUTION_NETWORK=testnet
HYPERLIQUID_MARGIN_MODE=isolated
HYPERLIQUID_PRIVATE_KEY=
TESTNET_CONFIRMATION=
TESTNET_MAX_ORDER_NOTIONAL_USD=25
TESTNET_SLIPPAGE_BPS=50
MAINNET_SLIPPAGE_BPS=30

# Used only when TRADING_PROFILE=experimental (PAPER/TESTNET).
EXPERIMENTAL_MIN_PLAN_CONVICTION=0.25
EXPERIMENTAL_MIN_OPEN_CONFIDENCE=0.30
EXPERIMENTAL_MAX_PORTFOLIO_RISK_FRAC=0.08
EXPERIMENTAL_MAX_NET_EXPOSURE_FRAC=2.0
EXPERIMENTAL_MAX_ASSET_NOTIONAL_USD=7500

# Grok is optional. PAPER runs deterministically without a key.
LLM_PROVIDER=rules
XAI_API_KEY=
XAI_MODEL=grok-4.20-0309-reasoning
X_SEARCH_ENABLED=false
X_ALLOWED_HANDLES=

# LIVE requires both a one-time risk gate and durable PostgreSQL storage.
LIVE_CONFIRMATION=
# Required only when LIVE and AUTOMATION_ENABLED=true; not a per-order confirmation.
LIVE_AUTOMATION_CONFIRMATION=
GUARDRAILS_CONFIGURED=true
